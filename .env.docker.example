# Used by compose.yaml. Copy to .env and replace this password.
POSTGRES_DB=forestudy
POSTGRES_USER=forestudy
POSTGRES_PASSWORD=change-this-to-a-long-random-password
FRONTEND_PORT=80
# Public TMAP JavaScript SDK key. Set this to the same TMAP app key used in
# backend/.env when building the frontend container.
VITE_TMAP_APP_KEY=

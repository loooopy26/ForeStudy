# Upstage API
UPSTAGE_API_KEY=up_xxxxxxxxxxxxxxxxxxxxxxxx

# TMAP API (SK Open API Network, https://openapi.sk.com) 앱 키
# 위치 기반 학습장소 추천 / 시험 당일 어시스턴트(/api/location/*)에 필요
TMAP_APP_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# Google Maps Platform Routes API (optional). When set, public-transit routes
# use Google Routes; TMAP continues to serve POI, walking, and driving routes.
GOOGLE_MAPS_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Naver Search API (블로그 검색). 주변 학습장소 추천(/api/location/nearby-study-places)에서
# "넓은/조용한/24시간" 같은 시설 조건을 실제 후기로 확인할 때 사용한다. 없으면 해당 기능만
# 건너뛰고 나머지 추천은 그대로 동작한다.
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# 아이템 이미지 생성(POST /items/generate)은 현재 Pollinations.ai(가입/키 불필요)를 쓰므로
# 별도 설정이 필요 없다. 나중에 fal.ai 등 유료 API로 바꾸면 여기에 키를 추가한다.

# PostgreSQL (pgvector 확장 필요: CREATE EXTENSION vector;)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/forestudy

# 모델 (기본값 그대로 사용 가능)
# UPSTAGE_CHAT_MODEL=solar-pro2
# UPSTAGE_EMBEDDING_PASSAGE_MODEL=solar-embedding-2-passage
# UPSTAGE_EMBEDDING_QUERY_MODEL=solar-embedding-2-query
